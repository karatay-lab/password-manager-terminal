# ─────────────────────────────────────────────────────────────
# pwd-manager-terminal — environment template
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Backend (see docs/api.md): X25519 ECDH key exchange + AES-256-GCM,
# device-token auth. The DEVICE TOKEN and the client's X25519 PRIVATE KEY
# are secrets and are NOT stored here — the app keeps them in an encrypted
# local store under PWM_DATA_DIR. Do not put any secret in this file.
# ─────────────────────────────────────────────────────────────

# Backend API base URL (host + port, no trailing slash)
PWM_API_BASE_URL=http://localhost:53971

# Network behavior
PWM_REQUEST_TIMEOUT_SECS=30
PWM_VERIFY_TLS=true

# Where the app keeps its ENCRYPTED local credential/state store
# (keypair, server pubkey, device-token, ehlo). Default per the UI spec.
PWM_DATA_DIR=~/.pwd-manager

# Copied secrets are wiped from the clipboard after this many seconds
PWM_CLIPBOARD_CLEAR_SECS=30

# Auto-lock the vault after this many seconds of inactivity (0 disables)
PWM_IDLE_LOCK_SECS=300

# Logging: error | warn | info | debug | trace
RUST_LOG=info
